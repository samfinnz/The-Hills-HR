# HR Project — copy to .env and edit if needed
#   cp .env.example .env

POSTGRES_USER=hr
POSTGRES_PASSWORD=hr_dev_pw
POSTGRES_DB=hrproject

PORT=3001

# Inside docker-compose, the API talks to the "hr-db" service.
# Values below are for running the API outside Docker against the
# port published to the host (5433 to avoid clashing with thehills-app's 5432).
DATABASE_URL=postgresql://hr:hr_dev_pw@localhost:5433/hrproject?schema=public
